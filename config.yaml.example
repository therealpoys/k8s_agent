llm:
  provider: openai        # "openai" | "anthropic" | "ollama"
  model: gpt-4o-mini      # e.g. gpt-4o, claude-sonnet-4-5, llama3.2
  timeout_seconds: 30

kubernetes:
  namespaces:
    - default             # add more namespaces as needed
  log_lines: 100

plugins:
  core:
    - pod_logs
  optional:
    trivy: false
    falco: false
    prometheus: false

outputs:
  - console

loop_interval_seconds: 60
